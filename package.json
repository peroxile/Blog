{
  "name": "blog",
  "version": "1.0.0",
  "description": "Secure personal blog with automated markdown synchronization",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:manifest": "tsx scripts/build.ts",
    "build": "pnpm build:manifest && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["blog", "markdown", "github"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "pnpm": {
    "overrides": {
      "js-yaml": "4.2.0",
      "uglify-js": "2.6.0"
    }
  }
}