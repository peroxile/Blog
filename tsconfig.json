{
    "compilerOptions": {
      "target": "ES2022",
      "useDefineForClassFields": true,
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
    "include": ["src/**/*.ts", "scripts/**/*.ts", "vite.config.ts"]
  }
  